                            style="width: 325px; padding: 10px 0; border: none; border-radius: 4px; background: #cea235; color: #000; font-size: 16px; font-weight: 500; cursor: pointer; opacity: @(string.IsNullOrWhiteSpace(newListName) || actionLoading ? "0.5" : "1");">
                        Crear nueva
                    </button>
                </div>
            </div>
        }
        else
        {
            <div style="height: 100%; text-align: center; margin: 0 36px; margin-inline-start: 36px; display: flex; flex-direction: column; padding: 16px 32px 48px;">
                <div style="font-size: 22px; font-family: Lato, Lato-fallback, Arial, sans-serif; color: #fff; padding-bottom: 14px; border-bottom: 1px solid #10161d; margin-bottom: 16px;">
                    Añadir a lista
                </div>
                <div style="flex: 1; overflow-y: auto; text-align: left; font-size: 18px; font-family: Lato, Lato-fallback, Arial, sans-serif; color: #fff;">
                    @if (watchlistListId.HasValue)
                    {
                        var watchlist = allLists.FirstOrDefault(l => l.Id == watchlistListId.Value);
                        if (watchlist is not null)
                        {
                            var inWatchlist = listItemIds?.ContainsKey(watchlistListId.Value) == true;
                            <div @onclick="() => AddToCustomList(watchlistListId!.Value)"
                                 style="display: flex; align-items: center; padding: 18px 14px; border-bottom: 1px solid #10161d; cursor: pointer;">
                                <i class="fa-solid fa-bookmark" style="color: #cea235; margin-right: 16px; width: 24px; font-size: 20px;"></i>
                                <span style="flex: 1; color: #fff;">@watchlist.Name</span>
                                @if (inWatchlist)
                                {
                                    <div style="width: 26px; height: 26px; background: #cea235; border-radius: 3px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fa-solid fa-check" style="color: #060D17; font-size: 16px;"></i>
                                    </div>
                                }
                                else
                                {
                                    <i class="fa-regular fa-square" style="color: #555; font-size: 26px;"></i>
                                }
                            </div>
                        }
                    }

                    @foreach (var list in allLists.Where(l => l.ListType == "custom").OrderBy(l => l.Name))
                    {
                        var inList = listItemIds?.ContainsKey(list.Id) == true;
                        <div @onclick="() => AddToCustomList(list.Id)"
                             style="display: flex; align-items: center; padding: 18px 14px; border-bottom: 1px solid #10161d; cursor: pointer;">
                            <i class="fa-solid fa-user" style="color: #cea235; margin-right: 16px; width: 24px; font-size: 20px;"></i>
                            <span style="flex: 1; color: #fff;">@list.Name</span>
                            @if (inList)
                            {
                                <div style="width: 26px; height: 26px; background: #cea235; border-radius: 3px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fa-solid fa-check" style="color: #060D17; font-size: 16px;"></i>
                                </div>
                            }
                            else
                            {
                                <i class="fa-regular fa-square" style="color: #555; font-size: 26px;"></i>
                            }
                        </div>
                    }

                    <div @onclick="() => showNewListForm = true"
                         style="display: flex; align-items: center; padding: 18px 14px; border-bottom: 1px solid #10161d; cursor: pointer;">
                        <i class="fa-solid fa-user" style="color: #cea235; margin-right: 16px; width: 24px; font-size: 20px;"></i>
                        <span style="flex: 1; color: #fff;">Crear nueva</span>
                        <i class="fa-solid fa-plus" style="color: #cea235; font-size: 26px;"></i>
                    </div>
                </div>
                <div style="padding: 16px 0; display: flex; justify-content: center;">
                    <button @onclick="CloseListSelector"
                            style="width: 325px; padding: 10px 0; border: 1px solid #cea23555; border-radius: 4px; background: #cea235; color: #000; font-size: 16px; font-weight: 500; cursor: pointer;">
                        Listo
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool loading = true;
    private string activeTab = "";
    private bool isMyListsTab => string.IsNullOrEmpty(activeTab);
    private bool isCustomListView => activeTab == "custom_lists" && selectedListId.HasValue;
    private string mediaFilter = "";
    private bool showFilters;
    private string? _openFilter;
    private string _sortOrder = "none";
    private readonly List<string> filterOptions =
    [
        "Año de estreno",
        "Calificación"
    ];

    private List<ListInfo> allLists = [];
    private List<ListInfo> customLists => allLists.Where(l => l.ListType == "custom").ToList();
    private List<ListItemModel> currentItems = [];
    private HashSet<string> _likedKeys = [];
    private HashSet<string> _dislikedKeys = [];
    private HashSet<string> _watchedKeys = [];
    private HashSet<string> _inAnyListKeys = [];
    private List<ListItemModel> sortedCurrentItems
    {
        get
        {
            if (_sortOrder == "none") return currentItems;
            return _sortOrder == "asc"
                ? currentItems.OrderBy(i => i.Title).ToList()
                : currentItems.OrderByDescending(i => i.Title).ToList();
        }
    }

    private int? selectedListId;
    private string currentListName = "";

    // Create
    private bool showCreateDialog;
    private bool creating;
    private string newListName = "";
    private string newListDescription = ""; // kept for compatibility

    // Edit
    private bool showEditDialog;
    private bool editing;
    private ListInfo? editingList;
    private string editListName = "";
    private string editListDescription = ""; // kept for compatibility

    // Delete
    private bool showDeleteConfirm;
    private bool deleting;
    private ListInfo? deleteTarget;

    // Add titles
    private bool showAddTitlesModal;
    private string addTitlesSearch = "";
    private List<TmdbMediaItem> addTitlesResults = [];
    private List<TmdbMediaItem> _addTitlesTrendingCache = [];
    private readonly HashSet<string> addTitlesInList = [];
    private readonly Dictionary<string, int> addTitlesItemIds = [];
    private CancellationTokenSource? _addTitlesCts;
    private bool addTitlesLoading;
    private ElementReference addTitlesSearchRef;
    private bool _focusAddTitlesSearch;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitAsync();
        if (!AuthService.IsLoggedIn)
        {
            loading = false;
            return;
        }

        ParseQueryParams();
        await LoadData();
        await LoadInAnyListKeysAsync();
        loading = false;
    }

    private void ParseQueryParams()
    {
        var qs = Nav.Uri;
        var idx = qs.IndexOf('?');
        if (idx < 0) return;

        var pairs = qs[(idx + 1)..].Split('&');
        foreach (var pair in pairs)
        {
            var parts = pair.Split('=', 2);
            if (parts.Length != 2) continue;
            var key = Uri.UnescapeDataString(parts[0]);
            var val = Uri.UnescapeDataString(parts[1]);

            if (key == "inner_tab") activeTab = val;
            else if (key == "list_id" && int.TryParse(val, out var lid)) selectedListId = lid;
        }
    }

    private async Task LoadData()
    {
        try
        {
            allLists = await ListsService.GetListsAsync();
        }
        catch
        {
            allLists = [];
            await AuthService.LogoutAsync();
            Nav.NavigateTo("login");
            return;
        }

        await LoadListStateAsync();

        if (isMyListsTab && !isCustomListView)
            return;

        var listId = selectedListId ?? GetDefaultListId(activeTab);
        if (listId.HasValue)
        {
            currentListName = allLists.FirstOrDefault(l => l.Id == listId.Value)?.Name ?? "";
            try
            {
                currentItems = await ListsService.GetListItemsAsync(listId.Value, string.IsNullOrEmpty(mediaFilter) ? null : mediaFilter);
            }
            catch
            {
                currentItems = [];
            }
        }
    }

    private int? GetDefaultListId(string tab)
    {
        return allLists.FirstOrDefault(l => l.ListType == tab)?.Id;
    }

    private static string GetPosterUrl(string? posterPath, string size = "w342")
    {
        return $"https://image.tmdb.org/t/p/{size}{posterPath}";
    }

    private void GoToMyLists() => SwitchTab("");
    private void GoToWatchlist() => SwitchTab("watchlist");
    private void GoToWatched() => SwitchTab("watched");
    private void GoToLiked() => SwitchTab("liked");

    private void ToggleFilters() => showFilters = !showFilters;

    private void ToggleFilterOption(string opt)
    {
        _openFilter = _openFilter == opt ? null : opt;
    }

    private void ResetFilters()
    {
        _openFilter = null;
    }

    private void HandleSortChanged(string order)
    {
        _sortOrder = order;
    }

    private void GoToCustomList(int id)
    {
        activeTab = "custom_lists";
        selectedListId = id;
        mediaFilter = "";
        currentListName = allLists.FirstOrDefault(l => l.Id == id)?.Name ?? "";
        Nav.NavigateTo($"listas?inner_tab=custom_lists&list_id={id}");
        _ = Reload();
    }

    private void SwitchTab(string tab)
    {
        activeTab = tab;
        selectedListId = null;
        mediaFilter = "";
        Nav.NavigateTo(tab == "" ? "listas" : $"listas?inner_tab={tab}");
        _ = Reload();
    }

    private async Task Reload()
    {
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadListStateAsync()
    {
        _likedKeys = [];
        _watchedKeys = [];
        var likedListId = allLists.FirstOrDefault(l => l.ListType == "liked")?.Id;
        var watchedListId = allLists.FirstOrDefault(l => l.ListType == "watched")?.Id;
        var tasks = new List<Task>();

        if (likedListId.HasValue)
            tasks.Add(LoadLikedAsync(likedListId.Value));
        if (watchedListId.HasValue)
            tasks.Add(LoadWatchedAsync(watchedListId.Value));

        await Task.WhenAll(tasks);
    }

    private async Task LoadLikedAsync(int listId)
    {
        try
        {
            var items = await ListsService.GetListItemsAsync(listId);
            _likedKeys = items.Select(i => $"{i.TmdbId}:{i.MediaType}").ToHashSet();
        }
        catch { _likedKeys = []; }
    }

    private async Task LoadWatchedAsync(int listId)
    {
        try
        {
            var items = await ListsService.GetListItemsAsync(listId);
            _watchedKeys = items.Select(i => $"{i.TmdbId}:{i.MediaType}").ToHashSet();
        }
        catch { _watchedKeys = []; }
    }

    private async Task LoadInAnyListKeysAsync()
    {
        _inAnyListKeys = [];
        var watchlistId = allLists.FirstOrDefault(l => l.ListType == "watchlist")?.Id;
        var tasks = new List<Task>();
        if (watchlistId.HasValue)
            tasks.Add(LoadInAnyListBucketAsync(watchlistId.Value));
        foreach (var cl in allLists.Where(l => l.ListType == "custom"))
            tasks.Add(LoadInAnyListBucketAsync(cl.Id));
        await Task.WhenAll(tasks);
    }

    private async Task LoadInAnyListBucketAsync(int listId)
    {
        try
        {
            var items = await ListsService.GetListItemsAsync(listId);
            foreach (var i in items)
                _inAnyListKeys.Add($"{i.TmdbId}:{i.MediaType}");
        }
        catch { }
    }

    private async Task ToggleLikedItem(ListItemModel item)
    {
        var likedListId = allLists.FirstOrDefault(l => l.ListType == "liked")?.Id;
        if (!likedListId.HasValue) return;
        var key = $"{item.TmdbId}:{item.MediaType}";
        await ListsService.InteractItemAsync(item.TmdbId, item.MediaType);
        try
        {
            if (_likedKeys.Contains(key))
            {
                _likedKeys.Remove(key);
                var items = await ListsService.GetListItemsAsync(likedListId.Value);
                var li = items.FirstOrDefault(i => i.TmdbId == item.TmdbId && i.MediaType == item.MediaType);
                if (li is not null)
                    await ListsService.RemoveItemFromListAsync(likedListId.Value, li.Id);
                await Tmdb.VoteAsync(item.MediaType, item.TmdbId, null);
                if (activeTab == "liked")
                    await LoadData();
            }
            else
            {
                _likedKeys.Add(key);
                if (_dislikedKeys.Contains(key))
                    _dislikedKeys.Remove(key);
                await ListsService.AddItemToListAsync(likedListId.Value, item.TmdbId, item.MediaType, item.Title, item.PosterPath, item.VoteAverage);
                await Tmdb.VoteAsync(item.MediaType, item.TmdbId, 10);
            }
        }
        catch { }
    }

    private async Task ToggleDislikedItem(ListItemModel item)
    {
        var key = $"{item.TmdbId}:{item.MediaType}";
        await ListsService.InteractItemAsync(item.TmdbId, item.MediaType);
        try
        {
            if (_dislikedKeys.Contains(key))
            {
                _dislikedKeys.Remove(key);
                await Tmdb.VoteAsync(item.MediaType, item.TmdbId, null);
            }
            else
            {
                _dislikedKeys.Add(key);
                if (_likedKeys.Contains(key))
                {
                    _likedKeys.Remove(key);
                    var likedListId = allLists.FirstOrDefault(l => l.ListType == "liked")?.Id;
                    if (likedListId.HasValue)
                    {
                        var items = await ListsService.GetListItemsAsync(likedListId.Value);
                        var li = items.FirstOrDefault(i => i.TmdbId == item.TmdbId && i.MediaType == item.MediaType);
                        if (li is not null)
                            await ListsService.RemoveItemFromListAsync(likedListId.Value, li.Id);
                    }
                    if (activeTab == "liked")
                        await LoadData();
                }
                await Tmdb.VoteAsync(item.MediaType, item.TmdbId, 0);
            }
        }
        catch { }
    }

    private async Task ToggleWatchedItem(ListItemModel item)
    {
        var watchedListId = allLists.FirstOrDefault(l => l.ListType == "watched")?.Id;
        if (!watchedListId.HasValue) return;
        var key = $"{item.TmdbId}:{item.MediaType}";
        await ListsService.InteractItemAsync(item.TmdbId, item.MediaType);
        try
        {
            if (_watchedKeys.Contains(key))
            {
                _watchedKeys.Remove(key);
                var items = await ListsService.GetListItemsAsync(watchedListId.Value);
                var li = items.FirstOrDefault(i => i.TmdbId == item.TmdbId && i.MediaType == item.MediaType);
                if (li is not null)
                    await ListsService.RemoveItemFromListAsync(watchedListId.Value, li.Id);
                if (activeTab == "watched")
                    await LoadData();
                if (item.MediaType == "tv")
                    await Tvmaze.ToggleAllTvEpisodesAsync(item.TmdbId, item.Title, false);
            }
            else
            {
                await ListsService.AddItemToListAsync(watchedListId.Value, item.TmdbId, item.MediaType, item.Title, item.PosterPath, item.VoteAverage);
                _watchedKeys.Add(key);
                if (item.MediaType == "tv")
                    await Tvmaze.ToggleAllTvEpisodesAsync(item.TmdbId, item.Title, true);
            }
        }
        catch { }
    }

    private ListItemModel? _listSelectorItem;
    private Dictionary<int, int>? listItemIds;
    private int? watchlistListId;
    private bool showCustomModal;
    private bool showNewListForm;
    private bool actionLoading;

    private async Task OpenListSelector(ListItemModel item)
    {
        var key = $"{item.TmdbId}:{item.MediaType}";
        await ListsService.InteractItemAsync(item.TmdbId, item.MediaType);
        _listSelectorItem = item;
        showCustomModal = true;
        await LoadLists();
        StateHasChanged();
    }

    private async Task CloseListSelector()
    {
        showCustomModal = false;
        showNewListForm = false;
        newListName = "";
        _listSelectorItem = null;
        await LoadData();
        await LoadListStateAsync();
        await LoadInAnyListKeysAsync();
        StateHasChanged();
    }

    private async Task LoadLists()
    {
        try
        {
            allLists = await ListsService.GetListsAsync();
            watchlistListId = allLists.FirstOrDefault(l => l.ListType == "watchlist")?.Id;
            listItemIds = [];
            if (_listSelectorItem is not null)
            {
                foreach (var list in allLists.Where(l => l.ListType == "watchlist" || l.ListType == "custom"))
                {
                    var items = await ListsService.GetListItemsAsync(list.Id);
                    var match = items.FirstOrDefault(i => i.TmdbId == _listSelectorItem.TmdbId);
                    if (match is not null)
                        listItemIds[list.Id] = match.Id;
                }
            }
        }
        catch { }
    }

    private async Task AddToCustomList(int listId)
    {
        if (_listSelectorItem is null) return;
        actionLoading = true;
        try
        {
            if (listItemIds?.ContainsKey(listId) == true)
            {
                await ListsService.RemoveItemFromListAsync(listId, listItemIds[listId]);
                listItemIds.Remove(listId);
            }
            else
            {
                var item = await ListsService.AddItemToListAsync(
                    listId, _listSelectorItem.TmdbId, _listSelectorItem.MediaType, _listSelectorItem.Title, _listSelectorItem.PosterPath, _listSelectorItem.VoteAverage);
                (listItemIds ??= [])[listId] = item.Id;
            }
        }
        catch { }
        actionLoading = false;
    }

    private async Task CreateNewListAndAdd()
    {
        if (string.IsNullOrWhiteSpace(newListName) || _listSelectorItem is null) return;
        actionLoading = true;
        try
        {
            var newList = await ListsService.CreateListAsync(newListName, null);
            var item = await ListsService.AddItemToListAsync(
                newList.Id, _listSelectorItem.TmdbId, _listSelectorItem.MediaType, _listSelectorItem.Title, _listSelectorItem.PosterPath, _listSelectorItem.VoteAverage);
            allLists.Add(new ListInfo
            {
                Id = newList.Id,
                Name = newList.Name,
                Description = newList.Description,
                ListType = newList.ListType
            });
            (listItemIds ??= [])[newList.Id] = item.Id;
            newListName = "";
            showNewListForm = false;
        }
        catch { }
        actionLoading = false;
    }

    private int GetFilteredCount() => mediaFilter switch
    {
        "movie" => currentItems.Count(i => i.MediaType == "movie"),
        "tv" => currentItems.Count(i => i.MediaType == "tv"),
        _ => currentItems.Count
    };

    private async Task FilterAll() { mediaFilter = ""; await LoadData(); }
    private async Task FilterMovies() { mediaFilter = "movie"; await LoadData(); }
    private async Task FilterSeries() { mediaFilter = "tv"; await LoadData(); }

    private async Task HandleCreateList()
    {
        if (string.IsNullOrWhiteSpace(newListName)) return;
        creating = true;
        try
        {
            await ListsService.CreateListAsync(newListName.Trim(), string.IsNullOrWhiteSpace(newListDescription) ? null : newListDescription.Trim());
            showCreateDialog = false;
            newListName = "";
            newListDescription = "";
        }
        catch { }
        creating = false;
        await LoadData();
        StateHasChanged();
    }

    private void CancelCreate() => showCreateDialog = false;

    private void StartEditList(ListInfo list)
    {
        editingList = list;
        editListName = list.Name;
        editListDescription = list.Description;
        showEditDialog = true;
    }

    private void CancelEdit() => showEditDialog = false;

    private async Task HandleEditList()
    {
        if (editingList == null || string.IsNullOrWhiteSpace(editListName)) return;
        editing = true;
        try
        {
            await ListsService.UpdateListAsync(editingList.Id, editListName.Trim(), string.IsNullOrWhiteSpace(editListDescription) ? "" : editListDescription.Trim());
            showEditDialog = false;
            editingList = null;
        }
        catch { }
        editing = false;
        await LoadData();
        StateHasChanged();
    }

    private void DeleteList(ListInfo list)
    {
        deleteTarget = list;
        showDeleteConfirm = true;
    }

    private void CancelDelete() => showDeleteConfirm = false;

    private async Task HandleDeleteList()
    {
        if (deleteTarget == null) return;
        deleting = true;
        try
        {
            await ListsService.DeleteListAsync(deleteTarget.Id);
            showDeleteConfirm = false;
            deleteTarget = null;
        }
        catch { }
        deleting = false;
        GoToMyLists();
    }

    private void GoToDetail(ListItemModel item)
    {
        Nav.NavigateTo($"media/{item.MediaType}/{item.TmdbId}");
    }

    private int GetListCount(string listType) =>
        allLists.FirstOrDefault(l => l.ListType == listType)?.ItemCount ?? 0;

    private async Task RemoveItem(ListItemModel item)
    {
        var listId = selectedListId ?? GetDefaultListId(activeTab);
        if (listId == null) return;
        try
        {
            await ListsService.RemoveItemFromListAsync(listId.Value, item.Id);
        }
        catch { }
        await LoadData();
        StateHasChanged();
    }

    private async Task ShareList()
    {
        var url = Nav.Uri;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
        }
        catch
        {
            // fallback: ignore
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusAddTitlesSearch)
        {
            _focusAddTitlesSearch = false;
            await addTitlesSearchRef.FocusAsync();
        }
    }

    private async Task OpenAddTitlesModal()
    {
        addTitlesSearch = "";
        addTitlesResults = [];
        addTitlesInList.Clear();
        addTitlesItemIds.Clear();
        showAddTitlesModal = true;
        _focusAddTitlesSearch = true;
        addTitlesLoading = true;
        try
        {
            foreach (var i in currentItems)
                addTitlesItemIds[$"{i.TmdbId}:{i.MediaType}"] = i.Id;
            var trending = await Tmdb.GetTrendingAsync();
            _addTitlesTrendingCache = trending.Where(i => i.MediaType == "movie" || i.MediaType == "tv").Take(20).ToList();
            addTitlesResults = [.. _addTitlesTrendingCache];
            MarkResultsInList();
        }
        catch { }
        addTitlesLoading = false;
    }

    private void CancelAddTitles()
    {
        _addTitlesCts?.Cancel();
        showAddTitlesModal = false;
    }

    private async Task OnAddTitlesSearchChanged()
    {
        _addTitlesCts?.Cancel();
        if (addTitlesSearch.Length < 3)
        {
            addTitlesResults = [.. _addTitlesTrendingCache];
            MarkResultsInList();
            return;
        }
        _addTitlesCts = new CancellationTokenSource();
        var token = _addTitlesCts.Token;
        addTitlesLoading = true;
        try
        {
            await Task.Delay(300, token);
            if (!token.IsCancellationRequested)
            {
                var results = await Tmdb.SearchAsync(addTitlesSearch);
                addTitlesResults = results.Where(i => i.MediaType == "movie" || i.MediaType == "tv").Take(20).ToList();
                MarkResultsInList();
            }
        }
        catch (TaskCanceledException) { }
        addTitlesLoading = false;
    }

    private void MarkResultsInList()
    {
        foreach (var item in addTitlesResults)
        {
            var key = $"{item.Id}:{item.MediaType}";
            if (addTitlesItemIds.ContainsKey(key))
                addTitlesInList.Add(key);
        }
    }

    private async Task ToggleAddTitle(TmdbMediaItem item)
    {
        var listId = selectedListId;
        if (listId == null) return;
        var key = $"{item.Id}:{item.MediaType}";
        await ListsService.InteractItemAsync(item.Id, item.MediaType);
        if (addTitlesInList.Contains(key))
        {
            if (addTitlesItemIds.TryGetValue(key, out var listItemId))
            {
                try
                {
                    await ListsService.RemoveItemFromListAsync(listId.Value, listItemId);
                    addTitlesInList.Remove(key);
                }
                catch { }
            }
        }
        else
        {
            try
            {
                await ListsService.AddItemToListAsync(
                    listId.Value, item.Id, item.MediaType, item.Title, item.PosterPath, item.VoteAverage);
                addTitlesInList.Add(key);
            }
            catch { }
        }
    }

    private async Task HandleAddTitles()
    {
        showAddTitlesModal = false;
        await LoadData();
        StateHasChanged();
    }
}