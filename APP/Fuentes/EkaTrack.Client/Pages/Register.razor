@page "/register"
@rendermode InteractiveWebAssembly
@inject NavigationManager Nav

<div class="register-closed-wrapper">
    <div class="register-closed-card">
        <div class="register-closed-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
        </div>
        <h2 class="register-closed-title">Registro cerrado</h2>
        <p class="register-closed-text">El registro de nuevas cuentas no está disponible.</p>
        <a href="login" class="register-closed-link">Volver al inicio de sesión</a>
    </div>
</div>

<style>
    .register-closed-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f3f4f6;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .register-closed-card {
        background: white;
        border-radius: 16px;
        padding: 48px 36px;
        width: 100%;
        max-width: 380px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        text-align: center;
        box-sizing: border-box;
    }

    .register-closed-icon {
        margin-bottom: 16px;
    }

    .register-closed-title {
        margin: 0 0 12px 0;
        font-size: 20px;
        font-weight: 600;
        color: #374151;
        font-family: inherit;
    }

    .register-closed-text {
        margin: 0 0 24px 0;
        font-size: 14px;
        color: #6b7280;
        line-height: 1.5;
    }

    .register-closed-link {
        display: inline-block;
        padding: 10px 24px;
        border-radius: 8px;
        background: #374151;
        color: white;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.15s;
    }

    .register-closed-link:hover {
        background: #1f2937;
    }
</style>
